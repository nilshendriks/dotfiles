{
  "defaultPolicy": {
    "tools": "ask",
    "bash": "ask",
    "mcp": "ask",
    "skills": "ask",
    "special": "ask"
  },
  "tools": {
    "read": "allow",
    "ls": "allow",
    "find": "allow",
    "grep": "allow",
    "fetch_content": "allow"
  },
  "bash": {
    "git status": "allow",
    "git diff*": "allow",
    "git log*": "allow",
    "tuxedo *": "allow"
  },
  "special": {
    "doom_loop": "deny"
  }
}
